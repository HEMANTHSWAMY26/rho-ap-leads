# .streamlit/secrets.toml.example
# ---------------------------------
# Copy this file to .streamlit/secrets.toml for local use,
# OR paste each key into Streamlit Cloud → App Settings → Secrets.
#
# DO NOT commit secrets.toml to version control.

APIFY_API_TOKEN = "your_apify_api_token_here"
TASK_US         = "your_us_task_id_here"
TASK_CANADA     = "your_canada_task_id_here"
GOOGLE_SHEET_ID = "your_google_sheet_id_here"

# Paste the full contents of your service_account.json here as a multi-line string:
GOOGLE_SERVICE_ACCOUNT_JSON = """
{
  "type": "service_account",
  "project_id": "...",
  "private_key_id": "...",
  "private_key": "-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n",
  "client_email": "...@....iam.gserviceaccount.com",
  "client_id": "...",
  "auth_uri": "https://accounts.google.com/o/oauth2/auth",
  "token_uri": "https://oauth2.googleapis.com/token"
}
"""
